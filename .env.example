# ============================================================
# Asistente Noreña — Variables de entorno
# Copiar a .env y completar los valores
# ============================================================

# ── LLM vía OpenRouter ──────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
GEMINI_API_KEY=

# Modelos configurables sin tocar código
AGENT_MODEL=openai/gpt-4.1-mini          # Agente LangGraph principal
OCR_MODEL=anthropic/claude-sonnet-4-5    # Claude Vision para OCR de facturas
AUDIO_TRANSCRIBE_PROVIDER=gemini
AUDIO_TRANSCRIBE_MODEL=gemini-2.5-flash

# ── Cohere (embeddings + reranker) ──────────────────────────
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-multilingual-v3.0
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=                  # Tu chat_id personal (único usuario autorizado)
# 'openclaw' (default) | 'direct' (fallback si OpenClaw falla)
TELEGRAM_MODE=openclaw

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://assistant:${POSTGRES_PASSWORD}@postgres:5432/assistant

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CHAT_BUFFER_SIZE=20                       # Últimos N mensajes de contexto conversacional

# ── Qdrant (instancia existente en dokploy-network) ─────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=norena_assistant
QDRANT_MAX_VECTORS=100000                 # Si supera este límite, borra los más antiguos
QDRANT_RETENTION_DAYS=365                 # Borra vectores más viejos que este margen

# ── Seguridad ────────────────────────────────────────────────
# Protege /v1/process y /v1/ocr — debe coincidir en openclaw.json
INTERNAL_API_KEY=

# ── Almacenamiento ───────────────────────────────────────────
PHOTOS_DIR=/app/photos                    # Directorio para fotos de facturas

# ── App ──────────────────────────────────────────────────────
TIMEZONE=America/Bogota
